# Token Bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API Key dari conduit.ozdoev.net
CONDUIT_API_KEY=your_conduit_api_key_here

# Base URL Conduit (bisa dibiarkan default)
CONDUIT_BASE_URL=https://conduit.ozdoev.net

# Model default yang digunakan
DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# Batas maksimal riwayat percakapan per chat (untuk menghemat token)
MAX_HISTORY=10
