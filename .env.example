# Token Bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API Key dari conduit.ozdoev.net (format: sk-cdt-...)
CONDUIT_API_KEY=sk-cdt-your_key_here

# Base URL Conduit (OpenAI-compatible) - WAJIB https:// dan /api/v1
CONDUIT_BASE_URL=https://conduit.ozdoev.net/api/v1

# Model default - gunakan id POLOS tanpa prefix provider
DEFAULT_MODEL=claude-sonnet-4-6

# Batas riwayat percakapan per chat
MAX_HISTORY=10

# Streaming respons real-time (true/false) - berlaku saat tools off
STREAM_ENABLED=true

# GitHub Client ID dari OAuth App (untuk login device flow)
GITHUB_CLIENT_ID=your_github_client_id_here
