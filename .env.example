# Token Bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API Key dari conduit.ozdoev.net (format: sk-cdt-...)
CONDUIT_API_KEY=sk-cdt-your_key_here

# Base URL Conduit (OpenAI-compatible) - WAJIB pakai https:// dan /api/v1
CONDUIT_BASE_URL=https://conduit.ozdoev.net/api/v1

# Model default
DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# Batas riwayat percakapan per chat
MAX_HISTORY=10

# Streaming respons real-time (true/false)
STREAM_ENABLED=true
